# Application
APP_NAME=Edge Asset Management
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://edge_user:edge_pass@localhost:5432/edge_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Broker - Tradovate
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=
TRADOVATE_DEMO=true

# Market Data
POLYGON_API_KEY=
# Alpaca IEX real-time feed (free tier) — PREFERRED futures data source.
# Set BOTH to make SPY/QQQ/IWM/DIA futures proxies go real-time:
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
RITHMIC_USER=
RITHMIC_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
